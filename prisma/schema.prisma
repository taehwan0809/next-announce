// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

model User {
  id            String   @id @default(cuid())
  email         String   @unique
  name          String?
  passwordHash  String?
  cognitoSub    String?  @unique
  emailVerified Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  presentations Presentation[]

  @@map("users")
}

model Presentation {
  id                   String   @id @default(cuid())
  title                String
  script               String?  @db.Text
  audioUrl             String
  targetMinDurationSec Int?
  targetMaxDurationSec Int?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  userId String?
  user   User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  transcript     Transcript?
  analysisResult AnalysisResult?
  feedback       Feedback?
  questions      Question[]

  @@map("presentations")
  @@index([userId])
}

model Transcript {
  id   String @id @default(cuid())
  text String @db.Text

  presentationId String       @unique
  presentation   Presentation @relation(fields: [presentationId], references: [id], onDelete: Cascade)

  @@map("transcripts")
}

model AnalysisResult {
  id       String @id @default(cuid())
  duration Int

  speakingSpeedWpm    Int
  speakingSpeedRating String

  fillerWordsTotal Int
  fillerWords      Json

  silencesTotal       Int
  silencesAvgDuration Float
  silencesLongest     Float

  presentationId String       @unique
  presentation   Presentation @relation(fields: [presentationId], references: [id], onDelete: Cascade)

  pronunciationAnalysis PronunciationAnalysis?

  @@map("analysis_results")
}

model PronunciationAnalysis {
  id   String @id @default(cuid())
  accuracy Int

  wellPronounced Json

  analysisResultId String         @unique
  analysisResult   AnalysisResult @relation(fields: [analysisResultId], references: [id], onDelete: Cascade)

  mistakes PronunciationMistake[]

  @@map("pronunciation_analyses")
}

model PronunciationMistake {
  id         String @id @default(cuid())
  expected   String
  recognized String
  position   Int
  severity   String

  pronunciationAnalysisId String
  pronunciationAnalysis   PronunciationAnalysis @relation(fields: [pronunciationAnalysisId], references: [id], onDelete: Cascade)

  @@map("pronunciation_mistakes")
  @@index([pronunciationAnalysisId])
}

model Feedback {
  id      String @id @default(cuid())
  overall String @db.Text
  score   Int

  strengths    Json
  improvements Json

  presentationId String       @unique
  presentation   Presentation @relation(fields: [presentationId], references: [id], onDelete: Cascade)

  @@map("feedbacks")
}

model Question {
  id         String @id @default(cuid())
  question   String @db.Text
  category   String
  difficulty String

  presentationId String
  presentation   Presentation @relation(fields: [presentationId], references: [id], onDelete: Cascade)

  @@map("questions")
  @@index([presentationId])
}
